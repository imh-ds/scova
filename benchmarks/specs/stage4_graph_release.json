  "seed_namespaces": {
    "smoke": 120000000,
    "calibration": 121000000,
    "validation": 122000000,
    "publication": 123000000
  },
  "notes": [
    "The validation namespace must never be used to tune gates, graph rules, or implementation choices.",
    "All graph-selection metrics are evaluated against the DGP's declared support truth, not observed outcomes.",
    "A failure in the pairwise-without-K-way scenario blocks Stage 4 promotion.",
    "Any change to the DGP, gate rules, API semantics, split policy, or inference procedure requires a new protocol and seed namespaces."
  ]
}
