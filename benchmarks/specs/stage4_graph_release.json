{
  "schema_version": 1,
  "protocol": "stage4-graph-firewall-v1",
  "status": "frozen",
  "frozen": true,
  "validation_level": "directional",
  "stage3_dependency": {
    "required_protocol": "stage3-directional-v1",
    "requires_calibrated_threshold_artifact": true,
    "allows_provisional_thresholds_for_smoke_only": true
  },
  "analysis_mode": {
    "selection": "outer_design_estimation_split",
    "design_fraction": 0.5,
    "outcome_blind_design": true,
    "confidence_level": 0.95,
    "multiplicity": "max-t over locked graph-supported family",
    "same_sample_selection": "out_of_scope"
  },
  "primary_factors": {
    "n_groups": [2, 4, 8],
    "n": [500, 2000],
    "p": [5, 20],
    "overlap": ["strong", "moderate", "weak", "near_violation", "pairwise_only"],
    "outcome": ["linear", "nonlinear", "threshold"],
    "imbalance": ["balanced", "rare"],
    "error": ["normal", "heteroskedastic"],
    "null_regime": ["global_null", "sparse_pairwise_signal"]
  },
  "candidate_subsets": {
    "pairs": "all",
    "subsets": "all_subsets_up_to_size_4",
    "global_claims": "supported_maximal_cliques_only"
